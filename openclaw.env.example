# Copy to ./openclaw.env (do not commit secrets) and adjust values.

# Gateway shared-secret auth token used by relay and Control UI.
OPENCLAW_GATEWAY_TOKEN=

# LLM provider (OpenRouter). After backend-proxy migration this can be any non-empty stub.
OPENROUTER_API_KEY=replace-me

# Host port bindings (localhost-only).
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# Gateway bind mode (OpenClaw supports values like "lan").
OPENCLAW_GATEWAY_BIND=lan

# Allow starting without configured channel integrations.
OPENCLAW_SKIP_CHANNELS=1

