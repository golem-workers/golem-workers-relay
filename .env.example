BACKEND_BASE_URL=https://api.example.com
RELAY_TOKEN=replace-me
# Optional explicit repo/update branch override for scripts/setup.sh and scripts/update-repo.sh.
# APP_GIT_REF=release
# Optional Ubuntu package mirror overrides for scripts/prepare-agent-server.sh.
# When unset, the script auto-selects fast defaults and prefers Hetzner mirrors on Hetzner hosts.
# APT_MIRROR_HINT=hetzner
# UBUNTU_SUITE=noble
# APT_MIRROR=https://mirror.hetzner.com/ubuntu/packages
# APT_SECURITY_MIRROR=https://mirror.hetzner.com/ubuntu/security

# Optional
RELAY_INSTANCE_ID=
RELAY_CHAT_BATCH_DEBOUNCE_MS=500
RELAY_LOW_DISK_ALERT_ENABLED=1
RELAY_LOW_DISK_ALERT_THRESHOLD_PERCENT=80
RELAY_CONCURRENCY=1
RELAY_PUSH_PORT=18790
RELAY_PUSH_PATH=/relay/messages
RELAY_OPENROUTER_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_OPENROUTER_PROXY_PORT=18080
RELAY_OPENROUTER_PROXY_PATH_PREFIX=/provider-proxy/openrouter
RELAY_OPENROUTER_BACKEND_PATH_PREFIX=/api/v1/relays/openrouter
RELAY_JINA_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_JINA_PROXY_PORT=18082
RELAY_JINA_PROXY_PATH_PREFIX=/provider-proxy/jina
RELAY_JINA_BACKEND_PATH_PREFIX=/api/v1/relays/jina
RELAY_GOOGLE_AI_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_GOOGLE_AI_PROXY_PORT=18081
RELAY_GOOGLE_AI_PROXY_PATH_PREFIX=/provider-proxy/google-ai
RELAY_GOOGLE_AI_BACKEND_PATH_PREFIX=/api/v1/relays/google-ai
RELAY_ELEVENLABS_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_ELEVENLABS_PROXY_PORT=18086
RELAY_ELEVENLABS_PROXY_PATH_PREFIX=/provider-proxy/elevenlabs
RELAY_ELEVENLABS_BACKEND_PATH_PREFIX=/api/v1/relays/elevenlabs
RELAY_FAL_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_FAL_PROXY_PORT=18087
RELAY_FAL_PROXY_PATH_PREFIX=/provider-proxy/fal
RELAY_FAL_BACKEND_PATH_PREFIX=/api/v1/relays/fal
RELAY_RUNWAY_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_RUNWAY_PROXY_PORT=18085
RELAY_RUNWAY_PROXY_PATH_PREFIX=/provider-proxy/runway
RELAY_RUNWAY_BACKEND_PATH_PREFIX=/api/v1/relays/runway
RELAY_MOONSHOT_PROXY_ENABLED=1
# Listener binds to 127.0.0.1 by default.
RELAY_MOONSHOT_PROXY_PORT=18083
RELAY_MOONSHOT_PROXY_PATH_PREFIX=/provider-proxy/moonshot
RELAY_MOONSHOT_BACKEND_PATH_PREFIX=/api/v1/relays/moonshot
RELAY_OPENCLAW_FORWARD_FINAL_ONLY=1

# relay-channel plugin: loopback control plane (WebSocket) + local HTTP data plane
RELAY_CHANNEL_ENABLED=1
RELAY_CHANNEL_CONTROL_PLANE_HOST=127.0.0.1
RELAY_CHANNEL_CONTROL_PLANE_PORT=43129
RELAY_CHANNEL_DATA_PLANE_HOST=127.0.0.1
RELAY_CHANNEL_DATA_PLANE_PORT=43130
# Runtime relay-channel plugin drift check. Relay syncs the repo ref below,
# compares the built package version against the installed OpenClaw plugin
# version, and reinstalls when the installed version is older.
RELAY_CHANNEL_PLUGIN_AUTO_UPDATE_ENABLED=1
RELAY_CHANNEL_PLUGIN_REPO_DIR=/root/golem-workers-openclaw-channel-plugin
RELAY_CHANNEL_PLUGIN_REPO_URL=https://github.com/golem-workers/golem-workers-openclaw-channel-plugin.git
RELAY_CHANNEL_PLUGIN_GIT_REF=release

# Unified message flow logging (messenger <-> backend <-> relay <-> OpenClaw)
MESSAGE_FLOW_LOG=1

# OpenClaw Gateway
OPENCLAW_GATEWAY_WS_URL=ws://127.0.0.1:18789
OPENCLAW_CONFIG_PATH=
OPENCLAW_STATE_DIR=
OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_PASSWORD=
OPENCLAW_SCOPES=operator.admin
# Relay-side watchdog budget for missed gateway ticks. Effective timeout is
# hello.policy.tickIntervalMs * RELAY_OPENCLAW_TICK_TIMEOUT_MULTIPLIER.
RELAY_OPENCLAW_TICK_TIMEOUT_MULTIPLIER=10

# Optional STT (voice-to-text) via the backend OpenAI relay-auth proxy.
OPENAI_STT_BASE_URL=http://localhost:3000/api/v1/relays/openai
OPENAI_STT_MODEL=gpt-4o-transcribe
STT_TIMEOUT_MS=15000

